{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "<", "close": ">" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "onEnterRules": [
    {
      "beforeText": "<([a-zA-Z][\\w:-]*)(?:\"[^\"]*\"|'[^']*'|[^'\">])*>(?![^<]*</\\1>)",
      "afterText": "^</([a-zA-Z][\\w:-]*)>",
      "action": { "indent": "indentOutdent" }
    },
    {
      "beforeText": "<([a-zA-Z][\\w:-]*)(?:\"[^\"]*\"|'[^']*'|[^'\">])*>",
      "action": { "indent": "indent" }
    }
  ]
}
