{
  "name": "rpml-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/renderer-web dev",
    "build": "bun run --cwd packages/renderer-web build",
    "build:all": "bun run --cwd packages/renderer-web build && bun run --cwd packages/parser build && bun run --cwd packages/validator build",
    "typecheck": "bun run --cwd packages/renderer-web typecheck",
    "validate": "bun packages/validator/src/cli.ts",
    "compile": "bun packages/compiler/src/cli.ts"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.474.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3"
  }
}